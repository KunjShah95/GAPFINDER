# ============================================================================
# GapMiner Server Environment Variables
# Copy to .env and fill in your values
# ============================================================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/gapminer
DB_POOL_MAX=20

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# Firecrawl API (Web Scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ============================================================================
# AI Provider API Keys
# Configure ONE or MORE providers. The first configured provider will be used as default.
# Set DEFAULT_AI_PROVIDER to specify which provider to use by default.
# ============================================================================

# Default AI provider: gemini, openai, anthropic, openrouter, deepseek, mistral, cohere
DEFAULT_AI_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenRouter (Aggregates multiple providers - recommended for flexibility)
# Get free credits at: https://openrouter.ai/
OPENROUTER_API_KEY=

# DeepSeek (Cheap & fast)
DEEPSEEK_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================================================
# Payments Configuration
# Set PAYMENT_PROVIDER to 'stripe' or 'razorpay'
# ============================================================================
PAYMENT_PROVIDER=stripe

# Stripe (Global - USD, EUR, GBP, etc.)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (India/Asia - INR)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================================================================
# Email Provider
# Options: sendgrid, mailgun, ses, console (development)
# ============================================================================
EMAIL_PROVIDER=console
SENDGRID_API_KEY=
# Or use Mailgun:
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# ============================================================================
# Monitoring (Optional - recommended for production)
# ============================================================================
SENTRY_DSN=
