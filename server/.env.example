# ============================================================================
# GAPMINER BACKEND - ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# DATABASE — PostgreSQL 14+ with pgvector
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/gapminer
DB_POOL_MAX=20

# ============================================================================
# MESSAGE QUEUE & CACHE — Redis 7+
# Used for background jobs (Firecrawl scrape + AI analysis)
# ============================================================================
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=gapminer:
QUEUE_CONCURRENCY=5
QUEUE_DEFAULT_RETRIES=3
QUEUE_BACKOFF_DELAY=1000

# IMPORTANT: Set to "true" on ONLY ONE API instance (primary scheduler)
# All other instances and all worker instances should have this set to "false"
RUN_LATEST_PAPERS_CRON=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ============================================================================
# WEB SCRAPING — Firecrawl (for extracting paper content from URLs)
# Get API key: https://www.firecrawl.dev
# ============================================================================
FIRECRAWL_API_KEY=

# ============================================================================
# AI PROVIDER API KEYS
# Configure ONE or MORE providers (will use first configured in this order).
# The Worker uses these for gap analysis, prompting, and related tasks.
# ============================================================================

# Default AI provider: gemini, openai, anthropic, openrouter, deepseek, mistral, cohere
DEFAULT_AI_PROVIDER=gemini

# ✅ Google Gemini (RECOMMENDED — Free tier, good for research, low cost)
# Get free API key: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=

# OpenAI (GPT-4, GPT-4o — high cost but excellent quality)
# Get API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (strong reasoning, Claude 3 models)
# Get API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter (aggregates 200+ models, free tier available)
# Get free credits: https://openrouter.ai/
OPENROUTER_API_KEY=

# DeepSeek (cheap, fast reasoning models)
DEEPSEEK_API_KEY=

# Mistral AI (French, fast, good price)
MISTRAL_API_KEY=

# Cohere (good for classification, embedding models)
COHERE_API_KEY=

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================================================
# PAYMENT PROCESSING
# Set PAYMENT_PROVIDER to 'stripe' or 'razorpay' based on your market
# ============================================================================
PAYMENT_PROVIDER=stripe

# Stripe (Global markets: USD, EUR, GBP, etc.)
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (India & select Asian markets: INR)
# Get keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================================================================
# EMAIL PROVIDER
# Options: sendgrid, mailgun, ses, console (development)
# ============================================================================
EMAIL_PROVIDER=console
SENDGRID_API_KEY=

# Mailgun (European GDPR-friendly alternative to SendGrid):
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# ============================================================================
# MONITORING & OBSERVABILITY (Optional — recommended for production)
# ============================================================================

# Sentry (error tracking & performance monitoring)
# Get DSN: https://sentry.io/
SENTRY_DSN=

# Log level: error | warn | info | debug
LOG_LEVEL=info
