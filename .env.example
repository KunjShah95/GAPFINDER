# GapMiner Frontend Environment Variables
# Copy to .env and fill in your values for local development

# Backend API URL (for development — proxied in production)
VITE_API_URL=http://localhost:3001/api

# App Configuration
VITE_APP_NAME=GapMiner
VITE_APP_URL=http://localhost:5173

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Monitoring (Optional - recommended for production)
VITE_SENTRY_DSN=

# NOTE: API keys are kept on the backend server only (see server/.env.example).
# The values below are placeholder sentinels — they enable proxy mode.
# Do NOT put real API keys here; they would be bundled into client-side JavaScript.
VITE_GEMINI_API_KEY=backend-proxy
VITE_FIRECRAWL_API_KEY=backend-proxy
